# ListerPros Blog Agent Configuration
# Copy this file to config.env and fill in your values
# Then run: source config.env && python3 blog_agent.py

# Required: Grok API Key (xAI - cheaper than Anthropic)
# Get yours at: https://console.x.ai/
GROK_API_KEY="your-grok-api-key-here"

# Optional: Netlify deployment
# Get these from: https://app.netlify.com/
NETLIFY_SITE_ID="your-netlify-site-id"
NETLIFY_AUTH_TOKEN="your-netlify-auth-token"

# Export all variables
export GROK_API_KEY
export NETLIFY_SITE_ID
export NETLIFY_AUTH_TOKEN
